

#VGA Pin
set_property PACKAGE_PIN G19 [get_ports {VGA_R[0]}]
    set_property IOSTANDARD LVCMOS33 [get_ports {VGA_R[0]}]
set_property PACKAGE_PIN H19 [get_ports {VGA_R[1]}]
    set_property IOSTANDARD LVCMOS33 [get_ports {VGA_R[1]}]
